# 浏览器扩展模式环境变量

# LinkPreview API 配置
# 用于自动获取网页标题和描述
# 免费注册：https://my.linkpreview.net (60次/小时)
VITE_LINKPREVIEW_API_KEY=

# AI 功能配置
# 推荐使用本地 API 端点（减少网络延迟）
VITE_OPENAI_API_KEY=
VITE_CUSTOM_API_BASE_URL=https://api.siliconflow.cn/v1
VITE_CUSTOM_API_KEY=

# 扩展特定配置
VITE_APP_MODE=extension
VITE_STORAGE_BACKEND=chrome_storage
